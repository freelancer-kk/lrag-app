{
  "asar": true,
  "directories": {
    "buildResources": "dist/",
    "output": "release/"
  },
  "files": [
    "**/*",
    "!quantum-scripts",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json",
    {
      "from": "../dist",
      "filter": ["**/*"]
    },
    {
      "from": "node_modules/@langchain/core/dist/node_modules/.pnpm",
      "to": "node_modules/@langchain/core/dist/node_modules/.pnpm",
      "filter": ["**/*"]
    }    
  ],
  "appx": {
    "identityName": "Khaleque.LRag",
    "publisher": "CN=25CA5135-C2A6-4B06-AD5B-46AC014014CC",
    "publisherDisplayName": "Khaleque",
    "applicationId": "LRag", 
    "displayName": "LRag"
  },
  "win": {
    "icon": "dist/assets/icons",    
    "target": [
      "portable"
    ]
  },
  "portable": {
    "splashImage": "dist/assets/icons/electron.bmp"
  },
  "afterSign": "scripts/notarize.js",   
  "mac": {
    "icon": "dist/assets/icons",
    "hardenedRuntime": true,
    "entitlements": "entitlements.mac.plist",
    "entitlementsInherit": "entitlements.mac.plist",
    "gatekeeperAssess": false,
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "icon": "dist/assets/icons/favicon.png",
    "target": [
      "AppImage"
    ]
  }
}
